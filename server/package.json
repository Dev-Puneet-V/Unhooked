{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "docker-compose-dev": "docker compose --env-file ./src/shared/environment/.env.development up --build",
    "docker-compose-pro": "docker compose --env-file ./src/shared/environment/.env.production up --build",
    "docker-build": "docker build -t unhooked-server .",
    "start-docker": "npm run docker-build && docker run -e PORT=3000 -p 3000:3000 unhooked-server",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start-dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "start-test": "cross-env NODE_ENV=test node dist/index.js"
  },
  "keywords": [],
